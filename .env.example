# Vorlage — kopieren nach .env (gitignored) und ausfüllen. Keine echten Secrets committen.

# --- APIs ---
THE_ODDS_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=

# --- yeet.com (read-only; on-chain/subgraph/frontend) ---
YEET_RPC_URL=
YEET_SUBGRAPH_URL=

# --- Infrastruktur ---
DATABASE_URL=postgresql+psycopg://value:value@localhost:5432/valuebot
REDIS_URL=redis://localhost:6379/0

# --- Engine-Schwellen (Prefix VALUEBOT_, optional — Defaults in config/settings.py) ---
# VALUEBOT_MIN_ODDS=1.5
# VALUEBOT_MIN_EV=0.03
# VALUEBOT_MIN_EDGE=0.02
# VALUEBOT_DEVIG_METHOD=shin
# VALUEBOT_ROBUST_MODE=true
# VALUEBOT_KI_DELTA_CAP=0.06
# VALUEBOT_PARLAY_MIN_EV=0.08
